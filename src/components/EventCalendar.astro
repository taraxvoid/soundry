---
import { getCollection } from 'astro:content'
import EventSubscribe from './EventSubscribe.astro'

const allEvents = await getCollection('events')
const sortedEvents = allEvents.sort((a, b) =>
    a.data.date.localeCompare(b.data.date),
)

const formatDate = (dateStr: string) => {
    const date = new Date(`${dateStr}T12:00:00`)
    return date.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        year: 'numeric',
    })
}

const formatTime = (time: string) => {
    const [hours, minutes] = time.split(':')
    const hour = parseInt(hours, 10)
    const ampm = hour >= 12 ? 'PM' : 'AM'
    const displayHour = hour > 12 ? hour - 12 : hour === 0 ? 12 : hour
    return `${displayHour}:${minutes} ${ampm}`
}
---

<section class="section events-section" id="events">
  <div class="section-inner">
    <div class="events-header">
      <h2><wa-icon name="calendar" aria-hidden="true"></wa-icon> Upcoming Events</h2>
      <EventSubscribe />
    </div>

    <p class="no-events" id="no-events-message" hidden>
      No upcoming events scheduled yet — check back soon!
    </p>

    {
      sortedEvents.length > 0 && (
        <div class="events-grid" id="events-grid">
          {sortedEvents.map((event) => (
            <wa-card data-event-date={event.data.date}>
              <div class="flex-card-inner">
                {event.data.image && (
                  <img
                    src={event.data.image}
                    alt={event.data.title}
                    class="event-image"
                  />
                )}
                <div>
                  <div class="event-header">
                    <h3 class="event-title">{event.data.title}</h3>
                  </div>
                  <span class="event-date-badge">
                    {formatDate(event.data.date)}
                  </span>
                  <div class="event-details">
                    <span><wa-icon name="clock" aria-hidden="true"></wa-icon> {formatTime(event.data.time)}</span>
                    <span><wa-icon name="location-dot" aria-hidden="true"></wa-icon> {event.data.location}</span>
                    {event.data.price !== '0' && (
                      <span><wa-icon name="dollar-sign" aria-hidden="true"></wa-icon> ${event.data.price}</span>
                    )}
                    {event.data.price === '0' && <span><wa-icon name="dollar-sign" aria-hidden="true"></wa-icon> Free</span>}
                  </div>
                  {event.data.description && (
                    <p class="event-description">{event.data.description}</p>
                  )}
                  <div class="event-links">
                    <a href={`/events/${event.id}.ics`}>
                      <wa-icon name="calendar" aria-hidden="true"></wa-icon> Add to Calendar
                    </a>
                    {event.data.rsvpLink && (
                      <a
                        href={event.data.rsvpLink}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Learn More / RSVP →
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </wa-card>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  import { isEventPast } from '../utils/eventVisibility'

  const todayStr = new Date().toISOString().split('T')[0]
  const grid = document.getElementById('events-grid')
  const noEventsMessage = document.getElementById('no-events-message')

  let visibleCount = 0
  for (const card of grid?.querySelectorAll('[data-event-date]') ?? []) {
    const isPast = isEventPast(card.getAttribute('data-event-date') ?? '', todayStr)
    card.toggleAttribute('hidden', isPast)
    if (!isPast) visibleCount++
  }

  noEventsMessage?.toggleAttribute('hidden', visibleCount > 0)
</script>

<style>
  .flex-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .event-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }
  .event-image {
    width: 100%;
    max-height: 8rem;
    object-fit: cover;
    border-radius: 4px;
  }
  wa-card[hidden] {
    display: none !important;
  }
</style>
