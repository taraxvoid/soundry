  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "favicons": "^7.3.0",
    "husky": "^9.1.7",
    "yaml": "^2.9.0"
  },
