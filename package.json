{
    "name": "omahasoundry.com",
    "type": "module",
    "version": "2.0.0",
    "description": "Soundry — Omaha's Experimental Music Education Workshops",
    "scripts": {
        "dev": "astro dev",
        "start": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "check": "astro check",
        "check:content": "astro sync",
        "serve:cms": "bunx decap-server",
        "generate:logo": "bun run scripts/generate-logo-png.ts",
        "generate:favicons": "bun run scripts/generate-favicons.mjs",
        "generate": "bun run generate:logo && bun run generate:favicons",
        "format": "biome check --write .",
        "lint": "biome check .",
        "prepare": "husky",
        "test": "bun run test:unit && playwright test",
        "test:unit": "bun test test/*.test.js",
        "test:build": "bun test test/build.test.js",
        "test:data": "bun test test/data.test.js",
        "test:fast": "bun run lint && bun run test:data",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.3",
        "astro": "^6.4.8",
        "typescript": "^6.0.3",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@biomejs/biome": "^2.5.1",
        "@playwright/test": "^1.61.1",
        "@resvg/resvg-js": "^2.6.2",
        "favicons": "^7.3.0",
        "husky": "^9.1.7",
        "yaml": "^2.9.0"
    },
    "volta": {
        "node": "24.15.0"
    },
    "author": "Tara <1711810+taraxvoid@users.noreply.github.com>",
    "license": "MIT"
}
